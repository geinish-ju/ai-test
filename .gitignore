# DVC metadata can be committed without committing generated data files.
!data/
data/raw/**
!data/raw/**/
!data/raw/**/*.dvc
!data/raw/**/.gitignore
data/processed/**
!data/processed/**/
!data/processed/**/*.dvc
!data/processed/**/.gitignore
data/splits/**
!data/splits/**/
!data/splits/**/*.dvc
!data/splits/**/.gitignore
data/classification/**
!data/classification/**/
!data/classification/**/*.dvc
!data/classification/**/.gitignore
data/models/**
!data/models/**/
!data/models/**/*.dvc
!data/models/**/.gitignore
data/validation/**
!data/validation/**/
!data/validation/**/*.dvc
!data/validation/**/.gitignore
data/testing/**
!data/testing/**/
!data/testing/**/*.dvc
!data/testing/**/.gitignore
data/explainability/**
!data/explainability/**/
!data/explainability/**/*.dvc
!data/explainability/**/.gitignore
data/runs/**
!data/runs/**/
!data/runs/**/*.dvc
!data/runs/**/.gitignore
data/reports/**
